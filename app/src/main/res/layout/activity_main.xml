<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:paddingStart="32dp"
    android:paddingEnd="32dp"
    android:paddingTop="16dp"
    android:paddingBottom="32dp">

    <!-- Title: fixed distance from top -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/on_background"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Status: tight below title -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_stopped"
        android:textSize="18sp"
        android:textColor="@color/on_background_secondary"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Play button: floats and centers between status text and exclusive noise selectors -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPlayStop"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:text="@string/play"
        android:textSize="22sp"
        app:cornerRadius="80dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/statusText"
        app:layout_constraintBottom_toTopOf="@id/noiseExclusiveGroup"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Exclusive row: White, Pink, Brown (cannot blend) -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/noiseExclusiveGroup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:singleSelection="false"
        android:layout_marginBottom="6dp"
        app:layout_constraintBottom_toTopOf="@id/noiseDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWhite"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:textColor="@color/btn_toggle_text"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:text="@string/noise_white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPink"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:textColor="@color/btn_toggle_text"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:text="@string/noise_pink" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBrown"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:textColor="@color/btn_toggle_text"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:text="@string/noise_brown" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Visual divider between exclusive and blendable rows -->
    <View
        android:id="@+id/noiseDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/on_background_secondary"
        android:alpha="0.3"
        android:layout_marginBottom="6dp"
        app:layout_constraintBottom_toTopOf="@id/noiseBlendableGroup"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Blendable row: Ocean, Rain, Storm, Fan, Fire (up to 2 can mix) -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/noiseBlendableGroup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:singleSelection="false"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/volumeLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOcean"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="@color/btn_toggle_text"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:text="@string/noise_ocean" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRain"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="@color/btn_toggle_text"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:text="@string/noise_rain" />

<com.google.android.material.button.MaterialButton
            android:id="@+id/btnFan"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="@color/btn_toggle_text"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:text="@string/noise_fan" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFire"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="@color/btn_toggle_text"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:text="@string/noise_fire" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Volume label: tight above the seekbar -->
    <TextView
        android:id="@+id/volumeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/volume"
        android:textSize="16sp"
        android:textColor="@color/on_background_secondary"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/seekBarVolume"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Seekbar: fixed at the bottom -->
    <SeekBar
        android:id="@+id/seekBarVolume"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
